# Persistent clones and checkpoints (default: ./workspaces under project root)
# WORKSPACES_DIR=/absolute/path/to/workspaces

# Per-project config directory (default: ./projects under project root)
# PROJECTS_DIR=/absolute/path/to/projects

HOST=0.0.0.0
PORT=8766

# GitHub webhook secret (empty = skip HMAC verification, dev only)
WEBHOOK_SECRET=

# EVENT_ALLOWLIST=push,pull_request,workflow_run,issues,issue_comment
# REPO_ALLOWLIST=owner/repo

TRIGGER_KEYWORDS=/test,@jiri

WEBHOOK_DRY_RUN=false

# GitHub API (issues, comments)
GITHUB_TOKEN=
# GITHUB_DEFAULT_REPO=owner/repo

# Optional explicit test commands (comma-separated); empty = auto-detect
# TEST_COMMANDS=pytest,npm test
TEST_TIMEOUT=600

# UI smoke tests (Playwright; run: playwright install chromium)
UI_TEST_ENABLED=false
UI_TEST_BASE_URL=http://127.0.0.1:3000
UI_TEST_TIMEOUT_MS=30000
UI_TEST_PATHS=/

# OpenAI (planner + analyzer); optional but recommended
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Jannus peer (separate VPS)
JANNUS_API_URL=http://127.0.0.1:8765
# Same value as Jannus JIRI_PEER_SECRET (sent as X-Jiri-Secret)
# JANNUS_API_SECRET=
# Public URL of this Jiri (for optional callbacks from Jannus)
JIRI_PUBLIC_BASE_URL=http://127.0.0.1:8766
# Optional: validate inbound calls from Jannus (same value as Jannus JIRI_API_SECRET)
# JIRI_INBOUND_SECRET=

NEGOTIATION_MAX_ROUNDS=3

# LangSmith
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=jiri

# Telegram — dedicated Jiri bot
JIRI_TELEGRAM_BOT_TOKEN=
JIRI_TELEGRAM_CHAT_ID=
